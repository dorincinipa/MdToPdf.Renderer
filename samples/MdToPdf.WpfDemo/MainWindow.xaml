<Window x:Class="MdToPdf.WpfDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MdToPdf Demo" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Page Size:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="PageSizeCombo" Width="100" SelectedIndex="0" VerticalAlignment="Center">
                <ComboBoxItem Content="A4"/>
                <ComboBoxItem Content="Letter"/>
                <ComboBoxItem Content="Legal"/>
                <ComboBoxItem Content="A3"/>
            </ComboBox>

            <TextBlock Text="Orientation:" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <ComboBox x:Name="OrientationCombo" Width="100" SelectedIndex="0" VerticalAlignment="Center">
                <ComboBoxItem Content="Portrait"/>
                <ComboBoxItem Content="Landscape"/>
            </ComboBox>

            <TextBlock Text="Margins (pt):" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <TextBox x:Name="MarginBox" Width="50" Text="40" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBox Grid.Row="1" x:Name="MarkdownEditor"
                 AcceptsReturn="True" AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13"
                 TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button x:Name="GenerateBtn" Content="Generate PDF" Padding="16,6"
                    Click="GenerateBtn_Click"/>
            <Button x:Name="LoadSampleBtn" Content="Load Sample" Padding="16,6" Margin="8,0,0,0"
                    Click="LoadSampleBtn_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="StatusText" Margin="0,6,0,0"
                   Foreground="Gray" TextWrapping="Wrap"/>
    </Grid>
</Window>
